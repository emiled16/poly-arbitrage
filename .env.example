# PostgreSQL
POLY_ARB_POSTGRES_DB=poly_arbitrage
POLY_ARB_POSTGRES_USER=postgres
POLY_ARB_POSTGRES_PASSWORD=postgres
POLY_ARB_POSTGRES_DSN=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/poly_arbitrage

# RabbitMQ
POLY_ARB_RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/%2F
POLY_ARB_RABBITMQ_QUEUE=ingestion.jobs
POLY_ARB_RABBITMQ_DEAD_LETTER_EXCHANGE=ingestion.dead_letter
POLY_ARB_RABBITMQ_DEAD_LETTER_QUEUE=ingestion.jobs.dead_letter

# Ingestion retries and worker identity
POLY_ARB_INGESTION_MAX_ATTEMPTS=3
POLY_ARB_INGESTION_RETRY_BASE_DELAY=30
POLY_ARB_INGESTION_RETRY_MAX_DELAY=300
POLY_ARB_INGESTION_WORKER_ID=ingestion-worker-1

# Long-running scheduler service
POLY_ARB_INGESTION_SCHEDULER_INTERVAL_SECONDS=30
POLY_ARB_INGESTION_SCHEDULER_LIMIT=100

# Raw storage
POLY_ARB_RAW_STORE_BACKEND=local
POLY_ARB_RAW_STORE_CONTAINER=raw
POLY_ARB_RAW_STORE_ROOT=artifacts/datasets

# Optional S3-compatible raw storage via MinIO
POLY_ARB_MINIO_ENDPOINT=http://127.0.0.1:9000
POLY_ARB_MINIO_ACCESS_KEY=minioadmin
POLY_ARB_MINIO_SECRET_KEY=minioadmin
POLY_ARB_MINIO_REGION=us-east-1
POLY_ARB_MINIO_SESSION_TOKEN=

# Logging
POLY_ARB_LOG_LEVEL=INFO

CODEX_GITHUB_PERSONAL_ACCESS_TOKEN=gh_...